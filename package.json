{
  "name": "find-package-imports",
  "version": "0.1.1",
  "description": "A utility to find package imports in javascript / Typescript files.",
  "keywords": [
    "find",
    "package"
  ],
  "homepage": "https://github.com/OlofFredriksson/find-package-imports#readme",
  "bugs": {
    "url": "https://github.com/OlofFredriksson/find-package-imports/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlofFredriksson/find-package-imports.git"
  },
  "license": "MIT",
  "author": "Olof",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsc",
    "build": "node build.mts",
    "postbuild": "dts-bundle-generator src/index.ts -o dist/index.d.ts",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "run-s eslint prettier:check",
    "lint:fix": "run-s eslint:fix prettier:write",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "pretest": "npm run lint",
    "test": "vitest run",
    "postversion": "git push --follow-tags"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.6.9",
    "@forsakringskassan/eslint-config": "15.0.18",
    "@forsakringskassan/eslint-config-cli": "15.0.0",
    "@forsakringskassan/eslint-config-typescript": "15.0.19",
    "@forsakringskassan/eslint-config-vitest": "15.0.19",
    "@forsakringskassan/prettier-config": "3.7.3",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@types/node": "22.20.0",
    "dts-bundle-generator": "9.5.1",
    "esbuild": "0.28.1",
    "npm-pkg-lint": "5.1.9",
    "npm-run-all2": "9.0.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 11.0.0"
  }
}
